<ui:FluentWindow x:Class="TrainerStudApp.LoginWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 xmlns:controls="clr-namespace:TrainerStudApp.Presentation.Controls"
                 mc:Ignorable="d"
                 Title="TrainerStud"
                 Width="520"
                 MinHeight="560"
                 SizeToContent="Height"
                 MinWidth="520"
                 WindowStartupLocation="CenterScreen"
                 ExtendsContentIntoTitleBar="True"
                 WindowBackdropType="Mica"
                 ResizeMode="CanResizeWithGrip">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolVis" />
        <Style x:Key="AuthSectionTitle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="28" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="TextAlignment" Value="Center" />
            <Setter Property="Margin" Value="0,0,0,8" />
        </Style>
        <Style x:Key="AuthSubtitle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="18" />
            <Setter Property="Opacity" Value="0.68" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="TextAlignment" Value="Center" />
            <Setter Property="LineHeight" Value="26" />
            <Setter Property="Margin" Value="0,0,0,24" />
            <Setter Property="MaxWidth" Value="440" />
            <Setter Property="HorizontalAlignment" Value="Center" />
        </Style>
        <Style x:Key="AuthField" TargetType="ui:TextBox">
            <Setter Property="Margin" Value="0" />
            <Setter Property="Padding" Value="12,10,12,10" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="FontSize" Value="19" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>
        <Style x:Key="AuthPasswordField" TargetType="ui:PasswordBox">
            <Setter Property="Margin" Value="0" />
            <Setter Property="Padding" Value="12,10,12,10" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="FontSize" Value="19" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>
        <Style x:Key="AuthFieldLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="16" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,0,0,6" />
        </Style>
        <Style x:Key="AuthFieldHint" TargetType="TextBlock">
            <Setter Property="FontSize" Value="15" />
            <Setter Property="Opacity" Value="0.62" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="LineHeight" Value="20" />
            <Setter Property="Margin" Value="0,0,0,16" />
        </Style>
        <Style x:Key="AuthStepTitle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="17" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,4,0,12" />
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="TrainerStud — вход для ученика" />

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel VerticalAlignment="Center"
                        HorizontalAlignment="Center"
                        Margin="40,28,40,40"
                        MaxWidth="480">
                <Grid>
                <StackPanel Visibility="{Binding IsLoginView, Converter={StaticResource BoolVis}}">
                    <TextBlock Style="{StaticResource AuthSectionTitle}" Text="Вход" />
                    <TextBlock Style="{StaticResource AuthSubtitle}"
                               Text="Тренировка ЕГЭ и заказ проверки работы экспертом. Нужен аккаунт ученика на платформе." />

                    <TextBlock Text="{Binding StatusMessage}"
                               TextWrapping="Wrap"
                               TextAlignment="Center"
                               FontSize="17"
                               LineHeight="22"
                               Opacity="0.78"
                               Margin="0,0,0,8" />

                    <TextBlock Style="{StaticResource AuthFieldLabel}" Text="Электронная почта" />
                    <controls:UnderlineFieldChrome IsInvalid="{Binding LoginEmailInvalid}">
                        <ui:TextBox Style="{StaticResource AuthField}"
                                    PlaceholderText="например, you@school.ru"
                                    Text="{Binding LoginEmail, UpdateSourceTrigger=PropertyChanged}" />
                    </controls:UnderlineFieldChrome>
                    <TextBlock Style="{StaticResource AuthFieldHint}"
                               Text="Логин — тот же email, что при регистрации на платформе." />

                    <TextBlock Style="{StaticResource AuthFieldLabel}" Text="Пароль" />
                    <controls:UnderlineFieldChrome x:Name="LoginPwdChrome" IsInvalid="{Binding LoginPasswordInvalid}">
                        <ui:PasswordBox Style="{StaticResource AuthPasswordField}"
                                        PlaceholderText="••••••••"
                                        Password="{Binding LoginPassword, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    </controls:UnderlineFieldChrome>
                    <TextBlock Style="{StaticResource AuthFieldHint}"
                               Text="Не короче 8 символов. Пароль платформы, не от почты." />

                    <ui:Button Appearance="Primary" Content="Войти" HorizontalAlignment="Stretch"
                               MinHeight="44" Margin="0,8,0,0" FontSize="18"
                               Click="OnLoginClick" />

                    <TextBlock TextAlignment="Center" Margin="0,18,0,0" FontSize="17">
                        <Run Text="Нет аккаунта? " Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                        <Hyperlink Click="OnShowRegisterClick" TextDecorations="Underline" Focusable="True">
                            Зарегистрироваться
                        </Hyperlink>
                    </TextBlock>
                    <TextBlock TextAlignment="Center" Margin="0,8,0,0" FontSize="17">
                        <Hyperlink Click="OnShowPasswordResetClick" TextDecorations="Underline" Focusable="True">
                            Забыли пароль?
                        </Hyperlink>
                    </TextBlock>
                </StackPanel>

                <StackPanel Visibility="{Binding IsRegisterView, Converter={StaticResource BoolVis}}">
                    <TextBlock Style="{StaticResource AuthSectionTitle}" Text="Регистрация" />
                    <TextBlock Style="{StaticResource AuthSubtitle}"
                               Text="Два шага: сначала код на почту, затем имя и пароль для входа."
                               Visibility="{Binding ShowRegisterStepRequestCode, Converter={StaticResource BoolVis}}" />
                    <TextBlock Style="{StaticResource AuthSubtitle}"
                               Text="Введите код из письма, имя и пароль — так вы будете входить в TrainerStud."
                               Visibility="{Binding ShowRegisterStepConfirm, Converter={StaticResource BoolVis}}" />

                    <TextBlock Text="{Binding StatusMessage}"
                               TextWrapping="Wrap"
                               TextAlignment="Center"
                               FontSize="17"
                               LineHeight="22"
                               Opacity="0.78"
                               Margin="0,0,0,8" />

                    <StackPanel Visibility="{Binding ShowRegisterStepRequestCode, Converter={StaticResource BoolVis}}">
                        <TextBlock Style="{StaticResource AuthStepTitle}" Text="Шаг 1 из 2 — запрос кода на почту" />
                        <TextBlock Style="{StaticResource AuthFieldLabel}" Text="Электронная почта" />
                        <controls:UnderlineFieldChrome IsInvalid="{Binding RegisterEmailInvalid}">
                            <ui:TextBox Style="{StaticResource AuthField}"
                                        PlaceholderText="куда отправить письмо с кодом"
                                        Text="{Binding RegisterEmail, UpdateSourceTrigger=PropertyChanged}" />
                        </controls:UnderlineFieldChrome>
                        <TextBlock Style="{StaticResource AuthFieldHint}"
                                   Text="На этот адрес придёт письмо с кодом подтверждения." />
                        <ui:Button Appearance="Secondary" Content="Отправить код на email"
                                   HorizontalAlignment="Stretch" MinHeight="44" FontSize="18"
                                   Command="{Binding RegisterSendCodeCommand}" />
                    </StackPanel>

                    <StackPanel Visibility="{Binding ShowRegisterStepConfirm, Converter={StaticResource BoolVis}}">
                        <TextBlock Style="{StaticResource AuthStepTitle}" Text="Шаг 2 из 2 — завершение регистрации" />
                        <TextBlock TextWrapping="Wrap" FontSize="16" Opacity="0.75" Margin="0,0,0,14" LineHeight="22"
                                   Text="{Binding RegisterEmail, StringFormat=Код отправлен на: {0}}" />

                        <TextBlock Style="{StaticResource AuthFieldLabel}" Text="Код из письма" />
                        <controls:UnderlineFieldChrome IsInvalid="{Binding RegisterCodeInvalid}">
                            <ui:TextBox Style="{StaticResource AuthField}"
                                        PlaceholderText="вставьте код из письма"
                                        Text="{Binding RegisterCode, UpdateSourceTrigger=PropertyChanged}" />
                        </controls:UnderlineFieldChrome>
                        <TextBlock Style="{StaticResource AuthFieldHint}"
                                   Text="Код из письма платформы (не пароль от почты)." />

                        <TextBlock Style="{StaticResource AuthFieldLabel}" Text="Имя в системе" />
                        <controls:UnderlineFieldChrome IsInvalid="{Binding RegisterNameInvalid}">
                            <ui:TextBox Style="{StaticResource AuthField}"
                                        PlaceholderText="как показывать вас в интерфейсе"
                                        Text="{Binding RegisterName, UpdateSourceTrigger=PropertyChanged}" />
                        </controls:UnderlineFieldChrome>
                        <TextBlock Style="{StaticResource AuthFieldHint}"
                                   Text="Минимум 2 символа; логин остаётся email с шага 1." />

                        <TextBlock Style="{StaticResource AuthFieldLabel}" Text="Пароль для входа" />
                        <controls:UnderlineFieldChrome x:Name="RegisterPwdChrome" IsInvalid="{Binding RegisterPasswordInvalid}">
                            <ui:PasswordBox Style="{StaticResource AuthPasswordField}"
                                            PlaceholderText="не меньше 8 символов"
                                            Password="{Binding RegisterPassword, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        </controls:UnderlineFieldChrome>
                        <TextBlock Style="{StaticResource AuthFieldHint}"
                                   Text="Этот пароль используется на экране «Вход» вместе с email." />

                        <ui:Button Appearance="Primary" Content="Завершить регистрацию"
                                   HorizontalAlignment="Stretch" MinHeight="44" FontSize="18"
                                   Margin="0,8,0,0"
                                   Click="OnConfirmRegisterClick" />
                    </StackPanel>

                    <TextBlock TextAlignment="Center" Margin="0,22,0,0" FontSize="17">
                        <Run Text="Уже есть аккаунт? " Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                        <Hyperlink Click="OnShowLoginClick" TextDecorations="Underline" Focusable="True">
                            Войти
                        </Hyperlink>
                    </TextBlock>
                </StackPanel>

                <StackPanel Visibility="{Binding IsPasswordResetView, Converter={StaticResource BoolVis}}">
                    <TextBlock Style="{StaticResource AuthSectionTitle}" Text="Сброс пароля" />
                    <TextBlock Style="{StaticResource AuthSubtitle}"
                               Text="Запросите код на email, затем введите код и новый пароль."
                               Visibility="{Binding ShowPasswordResetStepRequest, Converter={StaticResource BoolVis}}" />
                    <TextBlock Style="{StaticResource AuthSubtitle}"
                               Text="Введите код из письма и придумайте новый пароль для входа."
                               Visibility="{Binding ShowPasswordResetStepConfirm, Converter={StaticResource BoolVis}}" />

                    <TextBlock Text="{Binding StatusMessage}"
                               TextWrapping="Wrap"
                               TextAlignment="Center"
                               FontSize="17"
                               LineHeight="22"
                               Opacity="0.78"
                               Margin="0,0,0,8" />

                    <StackPanel Visibility="{Binding ShowPasswordResetStepRequest, Converter={StaticResource BoolVis}}">
                        <TextBlock Style="{StaticResource AuthStepTitle}" Text="Шаг 1 из 2 — код на почту" />
                        <TextBlock Style="{StaticResource AuthFieldLabel}" Text="Электронная почта" />
                        <controls:UnderlineFieldChrome IsInvalid="{Binding ResetEmailInvalid}">
                            <ui:TextBox Style="{StaticResource AuthField}"
                                        PlaceholderText="email учётной записи"
                                        Text="{Binding ResetEmail, UpdateSourceTrigger=PropertyChanged}" />
                        </controls:UnderlineFieldChrome>
                        <TextBlock Style="{StaticResource AuthFieldHint}"
                                   Text="Если адрес есть в системе, на него придёт код сброса." />
                        <ui:Button Appearance="Secondary" Content="Отправить код на email"
                                   HorizontalAlignment="Stretch" MinHeight="44" FontSize="18"
                                   Command="{Binding PasswordResetSendCodeCommand}" />
                    </StackPanel>

                    <StackPanel Visibility="{Binding ShowPasswordResetStepConfirm, Converter={StaticResource BoolVis}}">
                        <TextBlock Style="{StaticResource AuthStepTitle}" Text="Шаг 2 из 2 — новый пароль" />
                        <TextBlock TextWrapping="Wrap" FontSize="16" Opacity="0.75" Margin="0,0,0,14" LineHeight="22"
                                   Text="{Binding ResetEmail, StringFormat=Код отправлен на: {0}}" />

                        <TextBlock Style="{StaticResource AuthFieldLabel}" Text="Код из письма" />
                        <controls:UnderlineFieldChrome IsInvalid="{Binding ResetCodeInvalid}">
                            <ui:TextBox Style="{StaticResource AuthField}"
                                        PlaceholderText="код сброса"
                                        Text="{Binding ResetCode, UpdateSourceTrigger=PropertyChanged}" />
                        </controls:UnderlineFieldChrome>
                        <TextBlock Style="{StaticResource AuthFieldHint}"
                                   Text="Код из письма платформы, срок действия ограничен." />

                        <TextBlock Style="{StaticResource AuthFieldLabel}" Text="Новый пароль" />
                        <controls:UnderlineFieldChrome x:Name="ResetPwdChrome" IsInvalid="{Binding ResetPasswordInvalid}">
                            <ui:PasswordBox Style="{StaticResource AuthPasswordField}"
                                            PlaceholderText="не меньше 8 символов"
                                            Password="{Binding ResetNewPassword, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        </controls:UnderlineFieldChrome>
                        <TextBlock Style="{StaticResource AuthFieldHint}"
                                   Text="После сохранения войдите с этим паролем на экране «Вход»." />

                        <ui:Button Appearance="Primary" Content="Сохранить новый пароль"
                                   HorizontalAlignment="Stretch" MinHeight="44" FontSize="18"
                                   Margin="0,8,0,0"
                                   Click="OnPasswordResetConfirmClick" />
                    </StackPanel>

                    <TextBlock TextAlignment="Center" Margin="0,22,0,0" FontSize="17">
                        <Run Text="Вспомнили пароль? " Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                        <Hyperlink Click="OnShowLoginFromResetClick" TextDecorations="Underline" Focusable="True">
                            Войти
                        </Hyperlink>
                    </TextBlock>
                </StackPanel>
                </Grid>

                <ui:ProgressRing Width="36"
                                 Height="36"
                                 HorizontalAlignment="Center"
                                 Margin="0,28,0,0"
                                 IsIndeterminate="{Binding IsBusy}"
                                 Visibility="{Binding IsBusy, Converter={StaticResource BoolVis}}" />
            </StackPanel>
        </ScrollViewer>
    </Grid>
</ui:FluentWindow>
