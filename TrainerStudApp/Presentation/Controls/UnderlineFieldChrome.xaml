<UserControl x:Class="TrainerStudApp.Presentation.Controls.UnderlineFieldChrome"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Focusable="False"
             SnapsToDevicePixels="True">
    <UserControl.Resources>
        <SolidColorBrush x:Key="AuthUnderlineAccentBrush" Color="#0078D4" />
        <SolidColorBrush x:Key="AuthUnderlineErrorBrush" Color="#D92D20" />
    </UserControl.Resources>
    <Grid Margin="0,0,0,4">
        <Border CornerRadius="5"
                Background="{DynamicResource ControlFillColorInputBrush}"
                SnapsToDevicePixels="True">
            <Border.Effect>
                <DropShadowEffect BlurRadius="10"
                                  Direction="270"
                                  ShadowDepth="1"
                                  Opacity="0.12"
                                  Color="#000000" />
            </Border.Effect>
            <Border BorderBrush="#D8D8D8"
                    BorderThickness="1"
                    CornerRadius="5"
                    Background="{DynamicResource ControlFillColorInputBrush}">
                <Grid ClipToBounds="True">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <ContentPresenter Grid.Row="0"
                                      Focusable="False"
                                      Content="{Binding InnerContent, RelativeSource={RelativeSource AncestorType=UserControl}}" />
                    <Border Grid.Row="1"
                            Height="3"
                            Margin="1,0,1,1"
                            CornerRadius="0,0,4,4">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="{StaticResource AuthUnderlineAccentBrush}" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsInvalid, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="True">
                                        <Setter Property="Background" Value="{StaticResource AuthUnderlineErrorBrush}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                    </Border>
                </Grid>
            </Border>
        </Border>
    </Grid>
</UserControl>
