<UserControl x:Class="ExpertAdminTrainerApp.Presentation.Views.ConstructorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:controls="clr-namespace:ExpertAdminTrainerApp.Presentation.Controls"
             Loaded="OnLoaded">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolVis" />
    </UserControl.Resources>

    <DockPanel Margin="8">
        <!-- Панель действий: основное слева, редкие — в меню -->
        <Border DockPanel.Dock="Bottom" Padding="8,6" Margin="0,6,0,0">
            <DockPanel>
                <TextBlock DockPanel.Dock="Right"
                           MaxWidth="420"
                           Margin="12,0,0,0"
                           VerticalAlignment="Center"
                           FontSize="14"
                           Opacity="0.6"
                           Text="{Binding ViewerStatus}"
                           TextAlignment="Right"
                           TextTrimming="CharacterEllipsis"
                           TextWrapping="NoWrap" />
                <StackPanel Orientation="Horizontal">
                    <ui:Button Margin="0,0,6,0"
                               Appearance="Primary"
                               Command="{Binding SaveTemplateCommand}"
                               Content="Сохранить" />
                    <!-- Flyout у DropDownButton в WPF UI — только ContextMenu; ui:Flyout не открывается -->
                    <ui:DropDownButton Margin="0,0,6,0"
                                       Appearance="Secondary"
                                       Content="Файл и сервер"
                                       ToolTip="Экспорт/импорт JSON и синхронизация с API (материал «Разметка бланков»)">
                        <ui:DropDownButton.Flyout>
                            <ContextMenu MinWidth="260"
                                         DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                                <MenuItem Focusable="False"
                                          FontWeight="SemiBold"
                                          Header="Локальный файл"
                                          IsEnabled="False" />
                                <MenuItem Command="{Binding ExportTemplateCommand}"
                                          Header="Экспорт JSON в файл…" />
                                <MenuItem Command="{Binding ImportTemplateCommand}"
                                          Header="Импорт JSON из файла…" />
                                <Separator />
                                <MenuItem Focusable="False"
                                          FontWeight="SemiBold"
                                          Header="Сервер (материал «Бланки»)"
                                          IsEnabled="False" />
                                <MenuItem Command="{Binding PushBlankTemplateToServerCommand}"
                                          Header="Отправить на сервер"
                                          ToolTip="Загрузить JSON разметки и привязать материал «Бланки» с заголовком «Разметка бланков (JSON)»" />
                                <MenuItem Command="{Binding PullBlankTemplateFromServerCommand}"
                                          Header="Загрузить с сервера"
                                          ToolTip="Скачать JSON по материалу «Разметка бланков (JSON)» для выбранного КИМ" />
                            </ContextMenu>
                        </ui:DropDownButton.Flyout>
                    </ui:DropDownButton>
                    <ui:Button Margin="0,0,6,0"
                               Command="{Binding UndoCommand}"
                               Content="↶ Отмена"
                               IsEnabled="{Binding CanUndo}" />
                    <ui:Button Command="{Binding RedoCommand}"
                               Content="↷ Вернуть"
                               IsEnabled="{Binding CanRedo}" />
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Sub-Tabs -->
        <TabControl TabStripPlacement="Top">

            <!-- ===== Sub-tab 1: Настройка варианта ===== -->
            <TabItem Header="1. Настройка варианта">
                <Grid Margin="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="360" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="0,0,16,0">
                        <ui:TextBlock FontTypography="Subtitle" FontSize="19" Text="Вариант КИМ" Margin="0,0,0,8" />
                        <ComboBox ItemsSource="{Binding Cnns}" SelectedItem="{Binding SelectedCnn}"
                                  DisplayMemberPath="Subject" Margin="0,0,0,16" />

                        <ui:TextBlock FontTypography="Subtitle" FontSize="19" Text="Страницы бланков" Margin="0,0,0,8" />
                        <TextBlock Text="Выберите тип бланка и добавьте страницу. Для каждой страницы загрузите изображение (скан бланка)."
                                   TextWrapping="Wrap" Opacity="0.5" FontSize="14" Margin="0,0,0,8" />

                        <DockPanel Margin="0,0,0,8">
                            <ui:Button DockPanel.Dock="Right" Appearance="Primary" Content="+ Добавить"
                                       Command="{Binding AddPageCommand}" Margin="6,0,0,0" />
                            <ComboBox ItemsSource="{Binding BlankTypeOptions}"
                                      SelectedItem="{Binding NewPageBlankType}" />
                        </DockPanel>

                        <ListBox ItemsSource="{Binding Pages}" SelectedItem="{Binding SelectedPage}" MaxHeight="260">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <DockPanel Margin="4">
                                        <StackPanel>
                                            <TextBlock FontWeight="SemiBold">
                                                <Run Text="{Binding BlankType, Mode=OneWay}" />
                                                <Run Text=" — стр. " /><Run Text="{Binding PageNumber, Mode=OneWay}" />
                                            </TextBlock>
                                            <TextBlock Text="{Binding ImagePath, TargetNullValue='(изображение не загружено)'}"
                                                       TextTrimming="CharacterEllipsis" Opacity="0.5" FontSize="13" MaxWidth="280" />
                                        </StackPanel>
                                    </DockPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <WrapPanel Margin="0,8,0,0">
                            <ui:Button Content="Загрузить изображение" Appearance="Secondary" Margin="0,0,6,0"
                                       Command="{Binding LoadPageImageCommand}" />
                            <ui:Button Content="Удалить страницу" Appearance="Danger"
                                       Command="{Binding RemovePageCommand}" />
                        </WrapPanel>

                        <Separator Margin="0,16,0,12" />
                        <ui:TextBlock FontTypography="Subtitle" FontSize="19" Text="Эталоны автопроверки (по заданию)" Margin="0,0,0,6" />
                        <TextBlock TextWrapping="Wrap" Opacity="0.5" FontSize="13" Margin="0,0,0,6"
                                   Text="Сохраняются в JSON вместе с шаблоном; проверка на клиенте." />
                        <DataGrid ItemsSource="{Binding AutoAnswersEdit}" AutoGenerateColumns="False"
                                  CanUserAddRows="False" HeadersVisibility="Column" MaxHeight="160"
                                  Margin="0,0,0,6">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="№ задания" Binding="{Binding TaskId}" Width="80" />
                                <DataGridTextColumn Header="Ответ" Binding="{Binding Answer}" Width="*" />
                                <DataGridTemplateColumn Width="70">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <ui:Button Content="✕" Appearance="Transparent"
                                                       Command="{Binding DataContext.RemoveAutoAnswerRowCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                       CommandParameter="{Binding}" />
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                        <ui:Button Content="+ Строка эталона" Appearance="Secondary"
                                   Command="{Binding AddAutoAnswerRowCommand}" HorizontalAlignment="Left" />
                    </StackPanel>

                    <Border Grid.Column="1" Background="{DynamicResource ControlFillColorDefaultBrush}"
                            CornerRadius="8" Padding="8">
                        <Grid>
                            <TextBlock Text="Выберите страницу и загрузите изображение бланка"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                       Opacity="0.3" FontSize="16" TextWrapping="Wrap" TextAlignment="Center" />
                            <Image Source="{Binding PageImageSource}" Stretch="Uniform" VerticalAlignment="Top" />
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>

            <!-- ===== Sub-tab 2: Разметка зон ===== -->
            <TabItem Header="2. Разметка зон">
                <Grid Margin="4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="280" />
                    </Grid.ColumnDefinitions>

                    <DockPanel Grid.Column="0" Margin="0,0,8,0">
                        <Border DockPanel.Dock="Top" Padding="8" Margin="0,0,0,4"
                                Background="{DynamicResource ControlFillColorDefaultBrush}" CornerRadius="6">
                            <StackPanel>
                                <WrapPanel>
                                    <ui:Button Content="⇦ Выбрать" Margin="0,0,6,0" Command="{Binding SetModeSelectCommand}" />
                                    <ui:Button Content="▪ Ячейка" Margin="0,0,6,0" Command="{Binding SetModeStampSingleCommand}" />
                                    <ui:Button Content="▪▪▪ Ряд" Margin="0,0,6,0" Command="{Binding SetModeStampRowCommand}" />
                                    <ui:Button Content="▭ Прямоугольник" Margin="0,0,12,0"
                                               Command="{Binding SetModeDrawRectangleCommand}"
                                               ToolTip="Потяните мышью на бланке — одна зона (тип и режим ввода из панели справа)" />
                                    <Separator Margin="0,0,12,0" />
                                    <TextBlock Text="Кол-во:" VerticalAlignment="Center" Margin="0,0,4,0" Opacity="0.7" />
                                    <ui:TextBox Width="45" Text="{Binding RowCellCount}" Margin="0,0,10,0" />
                                    <TextBlock Text="Ш%:" VerticalAlignment="Center" Margin="0,0,4,0" Opacity="0.7" />
                                    <ui:TextBox Width="45" Text="{Binding CellWidth}" Margin="0,0,6,0" />
                                    <TextBlock Text="В%:" VerticalAlignment="Center" Margin="0,0,4,0" Opacity="0.7" />
                                    <ui:TextBox Width="45" Text="{Binding CellHeight}" Margin="0,0,6,0" />
                                    <TextBlock Text="Зазор%:" VerticalAlignment="Center" Margin="0,0,4,0" Opacity="0.7" />
                                    <ui:TextBox Width="45" Text="{Binding CellGap}" />
                                </WrapPanel>
                                <TextBlock TextWrapping="Wrap" Opacity="0.55" FontSize="13" Margin="0,6,0,0"
                                           Text="Режим «Выбрать»: Ctrl или Alt + клик — добавить/убрать зону в выделении. Shift+клик по зоне с группой — вся группа. «Прямоугольник»: зажать ЛКМ и протянуть. Режим «Выбрать»: перетаскивание двигает выделение. Список зон справа оставляет одну зону — для нескольких выделяйте на бланке." />
                            </StackPanel>
                        </Border>

                        <Border DockPanel.Dock="Top" Padding="6,4" Margin="0,0,0,4">
                            <DockPanel>
                                <TextBlock DockPanel.Dock="Left" Text="Страница:" VerticalAlignment="Center"
                                           FontWeight="SemiBold" Margin="0,0,8,0" />
                                <ComboBox ItemsSource="{Binding Pages}" SelectedItem="{Binding SelectedPage}"
                                          DisplayMemberPath="BlankType" />
                            </DockPanel>
                        </Border>

                        <Border Background="{DynamicResource ControlFillColorDefaultBrush}"
                                CornerRadius="6" ClipToBounds="True">
                            <Grid>
                                <TextBlock Text="Загрузите изображение бланка на вкладке «Настройка варианта»"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                           Opacity="0.3" FontSize="16" TextWrapping="Wrap" TextAlignment="Center" />
                                <controls:ZoneEditorCanvas x:Name="EditorCanvas"
                                    Focusable="True"
                                    ImageSource="{Binding PageImageSource}"
                                    Zones="{Binding CurrentZones}"
                                    SelectedZone="{Binding SelectedZone, Mode=OneWay}"
                                    HighlightedZones="{Binding SelectedZones}"
                                    SelectedZones="{Binding SelectedZones}"
                                    PendingPreset="{Binding PendingPresetTemplate, Mode=TwoWay}"
                                    EditorMode="{Binding EditorMode}"
                                    StampFieldType="{Binding StampFieldType}"
                                    StampFieldName="{Binding StampFieldName}"
                                    StampTaskNumber="{Binding StampTaskNumber}"
                                    StampInputMode="{Binding StampInputMode}"
                                    StampFieldRole="{Binding StampFieldRole}"
                                    CellWidthPercent="{Binding CellWidth}"
                                    CellHeightPercent="{Binding CellHeight}"
                                    RowCellCount="{Binding RowCellCount}"
                                    CellGapPercent="{Binding CellGap}"
                                    ZoneAdded="OnEditorZoneAdded"
                                    ZoneSelected="OnEditorZoneSelected"
                                    ZoneMutationStarting="OnZoneMutationStarting"
                                    PendingPresetConsumed="OnPendingPresetConsumed" />
                            </Grid>
                        </Border>
                    </DockPanel>

                    <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <ui:TextBlock FontTypography="BodyStrong" FontSize="17" Text="Пресеты (клик — затем по бланку)" Margin="0,0,0,6" />
                            <ListBox ItemsSource="{Binding ZonePresets}" MaxHeight="200" Margin="0,0,0,10"
                                     ScrollViewer.VerticalScrollBarVisibility="Auto">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding DisplayName}" TextWrapping="Wrap" FontSize="13" />
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem">
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                        <EventSetter Event="MouseDoubleClick" Handler="OnPresetDoubleClick" />
                                    </Style>
                                </ListBox.ItemContainerStyle>
                            </ListBox>

                            <ui:TextBlock FontTypography="BodyStrong" FontSize="17" Text="Параметры штампа" Margin="0,0,0,8" />
                            <TextBlock Text="Имя поля" Opacity="0.6" FontSize="13" Margin="0,0,0,2" />
                            <ui:TextBox Text="{Binding StampFieldName, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,6" />
                            <TextBlock Text="Тип поля" Opacity="0.6" FontSize="13" Margin="0,0,0,2" />
                            <ComboBox ItemsSource="{Binding FieldTypes}" SelectedItem="{Binding StampFieldType}" Margin="0,0,0,6" />
                            <TextBlock Text="Номер задания" Opacity="0.6" FontSize="13" Margin="0,0,0,2" />
                            <ui:TextBox Text="{Binding StampTaskNumber}" Margin="0,0,0,8" />

                            <Expander Header="Дополнительно (JSON / автопроверка)" IsExpanded="False" Margin="0,0,0,8">
                                <StackPanel Margin="0,6,0,0">
                                    <TextBlock TextWrapping="Wrap" FontSize="13" Opacity="0.65" Margin="0,0,0,8"
                                               Text="Обычно достаточно имени, типа и номера задания. Ниже — для экспорта шаблона и будущего клиента проверки: «роль» — стабильный код смысла (как в пресетах), «режим ввода» — ячейки или текст/рисунок. Эталоны автопроверки задаются в таблице на шаге 1 (по номеру задания)." />
                                    <TextBlock Text="Роль поля (fieldRole)" Opacity="0.6" FontSize="13" Margin="0,0,0,2" />
                                    <ui:TextBox Text="{Binding StampFieldRole, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,6" />
                                    <TextBlock Text="Режим ввода на клиенте" Opacity="0.6" FontSize="13" Margin="0,0,0,2" />
                                    <ComboBox ItemsSource="{Binding InputModes}" SelectedItem="{Binding StampInputMode}" />
                                </StackPanel>
                            </Expander>

                            <StackPanel Visibility="{Binding HasSelectedZone, Converter={StaticResource BoolVis}}">
                                <Separator Margin="0,0,0,8" />
                                <ui:TextBlock FontTypography="BodyStrong" FontSize="17" Text="Выбранные зоны" Margin="0,0,0,8" />
                                <ui:Button Content="Применить к выделенным" Appearance="Primary" Margin="0,0,0,4"
                                           Command="{Binding UpdateSelectedZoneCommand}" />
                                <ui:Button Content="Удалить выделенные" Appearance="Danger" Margin="0,0,0,4"
                                           Command="{Binding DeleteSelectedZoneCommand}" />
                                <ui:Button Content="Удалить всю группу" Appearance="Danger" Margin="0,0,0,4"
                                           Command="{Binding DeleteSelectedGroupCommand}" />
                                <ui:Button Content="Зазор группы (из панели)" Margin="0,0,0,4"
                                           Command="{Binding ApplyGroupGapCommand}" />
                                <ui:Button Content="Сгруппировать выделенные" Margin="0,0,0,4"
                                           Command="{Binding GroupSelectedZonesCommand}" />
                                <ui:Button Content="Разгруппировать" Margin="0,0,0,4"
                                           Command="{Binding UngroupSelectedCommand}" />
                            </StackPanel>

                            <Separator Margin="0,12,0,8" />
                            <ui:TextBlock FontTypography="BodyStrong" FontSize="17" Text="Зоны на странице" Margin="0,0,0,4" />
                            <TextBlock Opacity="0.5" FontSize="13" Margin="0,0,0,4">
                                <Run Text="Всего: " /><Run Text="{Binding CurrentZones.Count, Mode=OneWay}" />
                            </TextBlock>
                            <ListBox x:Name="ZonesSidebarList" MaxHeight="240" ItemsSource="{Binding CurrentZones}"
                                     SelectionChanged="OnZonesSidebarSelectionChanged">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock FontSize="13">
                                            <Run Text="{Binding FieldName, Mode=OneWay}" />
                                            <Run Text=" (" /><Run Text="{Binding FieldType, Mode=OneWay}" /><Run Text=")" />
                                        </TextBlock>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </TabItem>

            <!-- ===== Sub-tab 3: Обзор всех зон ===== -->
            <TabItem Header="3. Обзор зон">
                <DockPanel Margin="12">
                    <TextBlock DockPanel.Dock="Top" TextWrapping="Wrap" Opacity="0.5" FontSize="14" Margin="0,0,0,8"
                               Text="Все размеченные зоны текущей страницы. Выберите страницу в списке слева." />
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="200" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <DockPanel Grid.Column="0" Margin="0,0,12,0">
                            <TextBlock DockPanel.Dock="Top" Text="Страницы" FontWeight="SemiBold" Margin="0,0,0,6" />
                            <ListBox ItemsSource="{Binding Pages}" SelectedItem="{Binding SelectedPage}">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock FontSize="14">
                                            <Run Text="{Binding BlankType, Mode=OneWay}" />
                                            <Run Text=" (стр. " /><Run Text="{Binding PageNumber, Mode=OneWay}" /><Run Text=")" />
                                        </TextBlock>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </DockPanel>
                        <DataGrid x:Name="ZonesOverviewGrid" Grid.Column="1" ItemsSource="{Binding CurrentZones}"
                                  AutoGenerateColumns="False" IsReadOnly="True"
                                  CanUserSortColumns="True" CanUserReorderColumns="True"
                                  HeadersVisibility="Column" GridLinesVisibility="Horizontal" SelectionMode="Single"
                                  SelectionChanged="OnZonesOverviewSelectionChanged">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Имя поля" Binding="{Binding FieldName}" Width="*" />
                                <DataGridTextColumn Header="Тип" Binding="{Binding FieldType}" Width="90" />
                                <DataGridTextColumn Header="Роль" Binding="{Binding FieldRole}" Width="100" />
                                <DataGridTextColumn Header="Ввод" Binding="{Binding InputMode}" Width="70" />
                                <DataGridTextColumn Header="Группа" Binding="{Binding GroupId}" Width="90" />
                                <DataGridTextColumn Header="Задание" Binding="{Binding TaskNumber}" Width="60" />
                                <DataGridTextColumn Header="X %" Binding="{Binding X, StringFormat=F1}" Width="50" />
                                <DataGridTextColumn Header="Y %" Binding="{Binding Y, StringFormat=F1}" Width="50" />
                                <DataGridTextColumn Header="W %" Binding="{Binding Width, StringFormat=F1}" Width="50" />
                                <DataGridTextColumn Header="H %" Binding="{Binding Height, StringFormat=F1}" Width="50" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </DockPanel>
            </TabItem>
        </TabControl>
    </DockPanel>
</UserControl>
