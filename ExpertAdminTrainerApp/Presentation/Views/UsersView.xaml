<UserControl x:Class="ExpertAdminTrainerApp.Presentation.Views.UsersView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolVis" />
    </UserControl.Resources>

    <Grid Margin="8">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="420" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <DockPanel Grid.Column="0" Margin="0,0,8,0">
            <StackPanel DockPanel.Dock="Top" Margin="0,0,0,8">
                <TextBlock Text="Список пользователей" FontWeight="SemiBold" Margin="0,0,0,6" />
                <DockPanel Margin="0,0,0,4">
                    <ui:TextBox DockPanel.Dock="Left" Width="110" Margin="0,0,6,0" PlaceholderText="Роль (Expert)"
                                Text="{Binding UserRoleFilter, UpdateSourceTrigger=PropertyChanged}" />
                    <ui:TextBox PlaceholderText="Поиск по имени/email"
                                Text="{Binding UserSearch, UpdateSourceTrigger=PropertyChanged}" />
                </DockPanel>
                <ui:Button Appearance="Secondary" Content="Найти" Command="{Binding LoadUsersCommand}" />
            </StackPanel>
            <ListBox ItemsSource="{Binding Users}" SelectedItem="{Binding SelectedUser}">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Margin="4">
                            <TextBlock FontWeight="SemiBold" Text="{Binding Name, TargetNullValue='(без имени)'}" />
                            <TextBlock Text="{Binding Email}" Opacity="0.7" FontSize="14" />
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding Role}" Opacity="0.55" FontSize="13" Margin="0,0,8,0" />
                                <TextBlock Text="{Binding Balance, StringFormat=Баланс: {0}}" Opacity="0.55" FontSize="13"
                                           Visibility="{Binding Balance, Converter={StaticResource BoolVis}}" />
                            </StackPanel>
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </DockPanel>

        <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto" Padding="0,0,8,0">
            <Grid>
                <TextBlock Text="Выберите пользователя из списка" VerticalAlignment="Center" HorizontalAlignment="Center"
                           Opacity="0.4" FontSize="16"
                           Visibility="{Binding HasNoSelectedUser, Converter={StaticResource BoolVis}}" />
                <StackPanel Visibility="{Binding HasSelectedUser, Converter={StaticResource BoolVis}}">
                    <TextBlock Text="{Binding SelectedUser.Role, StringFormat=Текущая роль: {0}}"
                               Opacity="0.6" Margin="0,0,0,10" />

                    <ui:Card Padding="12" Margin="0,0,0,8">
                        <StackPanel>
                            <TextBlock Text="ФИО, email и пароль" FontWeight="SemiBold" Margin="0,0,0,6" />
                            <TextBlock Text="Сохраняет имя и email; пароль меняется только если поле ниже заполнено (не короче 8 символов)."
                                       Opacity="0.5" FontSize="14" TextWrapping="Wrap" Margin="0,0,0,10" />
                            <TextBlock Text="Отображаемое имя (ФИО)" Opacity="0.65" FontSize="13" Margin="0,0,0,4" />
                            <ui:TextBox Margin="0,0,0,10" Text="{Binding AdminEditUserName, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBlock Text="Электронная почта" Opacity="0.65" FontSize="13" Margin="0,0,0,4" />
                            <ui:TextBox Margin="0,0,0,10" Text="{Binding AdminEditUserEmail, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBlock Text="Новый пароль (необязательно)" Opacity="0.65" FontSize="13" Margin="0,0,0,4" />
                            <PasswordBox x:Name="AdminPasswordBox"
                                         Margin="0,0,0,10"
                                         Padding="8,6"
                                         FontSize="14"
                                         PasswordChanged="AdminPassword_OnPasswordChanged" />
                            <ui:Button Appearance="Primary" Content="Сохранить данные" Command="{Binding SaveAdminUserEditsCommand}" />
                        </StackPanel>
                    </ui:Card>

                    <ui:Card Padding="12" Margin="0,0,0,8"
                             Visibility="{Binding ShowAdminPromoteExpert, Converter={StaticResource BoolVis}}">
                        <StackPanel>
                            <TextBlock Text="Назначить роль Expert" FontWeight="SemiBold" Margin="0,0,0,6" />
                            <TextBlock Text="Доступно только для пользователей, которые ещё не Expert и не Admin. Сначала проверьте ФИО и email выше."
                                       Opacity="0.5" FontSize="14" TextWrapping="Wrap" Margin="0,0,0,8" />
                            <ui:Button Appearance="Secondary"
                                       Content="Назначить Expert"
                                       Command="{Binding PromoteToExpertCommand}" />
                        </StackPanel>
                    </ui:Card>

                    <ui:Card Padding="12" Margin="0,0,0,8"
                             Visibility="{Binding ShowAdminDemoteExpert, Converter={StaticResource BoolVis}}">
                        <StackPanel>
                            <TextBlock Text="Понизить до Student" FontWeight="SemiBold" Margin="0,0,0,6" />
                            <TextBlock Text="Только для роли Expert. Собственную учётную запись понизить нельзя."
                                       Opacity="0.5" FontSize="14" TextWrapping="Wrap" Margin="0,0,0,8" />
                            <ui:Button Appearance="Danger"
                                       Content="Понизить Expert → Student"
                                       Command="{Binding DemoteExpertToStudentCommand}" />
                        </StackPanel>
                    </ui:Card>

                    <ui:Card Padding="12" Visibility="{Binding ShowAdminExpertProfile, Converter={StaticResource BoolVis}}">
                        <StackPanel>
                            <TextBlock Text="Профиль эксперта (баланс)" FontWeight="SemiBold" Margin="0,0,0,6" />
                            <TextBlock Text="Создаёт запись ExpertInfo со стартовым балансом. Пользователь уже должен иметь роль Expert."
                                       Opacity="0.5" FontSize="14" TextWrapping="Wrap" Margin="0,0,0,8" />
                            <DockPanel Margin="0,0,0,8">
                                <TextBlock DockPanel.Dock="Left" Text="Стартовый баланс:" VerticalAlignment="Center" Margin="0,0,8,0" />
                                <ui:TextBox Width="100" Text="{Binding ExpertInfoBalance}" />
                            </DockPanel>
                            <ui:Button Content="Создать профиль" Command="{Binding CreateExpertInfoCommand}" />
                        </StackPanel>
                    </ui:Card>
                </StackPanel>
            </Grid>
        </ScrollViewer>
    </Grid>
</UserControl>
