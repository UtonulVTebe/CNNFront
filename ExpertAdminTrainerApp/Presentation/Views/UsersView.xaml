<UserControl x:Class="ExpertAdminTrainerApp.Presentation.Views.UsersView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolVis" />
    </UserControl.Resources>

    <Grid Margin="8">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="420" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <DockPanel Grid.Column="0" Margin="0,0,8,0">
            <StackPanel DockPanel.Dock="Top" Margin="0,0,0,8">
                <TextBlock Text="Список пользователей" FontWeight="SemiBold" Margin="0,0,0,6" />
                <DockPanel Margin="0,0,0,4">
                    <ui:TextBox DockPanel.Dock="Left" Width="110" Margin="0,0,6,0" PlaceholderText="Роль (Expert)"
                                Text="{Binding UserRoleFilter, UpdateSourceTrigger=PropertyChanged}" />
                    <ui:TextBox PlaceholderText="Поиск по имени/email"
                                Text="{Binding UserSearch, UpdateSourceTrigger=PropertyChanged}" />
                </DockPanel>
                <ui:Button Appearance="Secondary" Content="Найти" Command="{Binding LoadUsersCommand}" />
            </StackPanel>
            <ListBox ItemsSource="{Binding Users}" SelectedItem="{Binding SelectedUser}">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Margin="4">
                            <TextBlock FontWeight="SemiBold" Text="{Binding Name, TargetNullValue='(без имени)'}" />
                            <TextBlock Text="{Binding Email}" Opacity="0.7" FontSize="12" />
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding Role}" Opacity="0.55" FontSize="11" Margin="0,0,8,0" />
                                <TextBlock Text="{Binding Balance, StringFormat=Баланс: {0}}" Opacity="0.55" FontSize="11"
                                           Visibility="{Binding Balance, Converter={StaticResource BoolVis}}" />
                            </StackPanel>
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </DockPanel>

        <Border Grid.Column="1" Padding="8">
            <Grid>
                <TextBlock Text="Выберите пользователя из списка" VerticalAlignment="Center" HorizontalAlignment="Center"
                           Opacity="0.4" FontSize="14"
                           Visibility="{Binding HasNoSelectedUser, Converter={StaticResource BoolVis}}" />
                <StackPanel Visibility="{Binding HasSelectedUser, Converter={StaticResource BoolVis}}">
                    <ui:TextBlock FontTypography="Subtitle" Text="{Binding SelectedUser.Name}" Margin="0,0,0,4" />
                    <TextBlock Text="{Binding SelectedUser.Email}" Opacity="0.6" Margin="0,0,0,2" />
                    <TextBlock Text="{Binding SelectedUser.Role, StringFormat=Текущая роль: {0}}" Opacity="0.6" Margin="0,0,0,12" />
                    <ui:Card Padding="12" Margin="0,0,0,8">
                        <StackPanel>
                            <TextBlock Text="Назначить роль Expert" FontWeight="SemiBold" Margin="0,0,0,6" />
                            <TextBlock Text="Назначает роль Expert выбранному пользователю. После этого создайте профиль эксперта ниже."
                                       Opacity="0.5" FontSize="12" TextWrapping="Wrap" Margin="0,0,0,8" />
                            <ui:Button Appearance="Primary" Content="Назначить Expert" Command="{Binding PromoteToExpertCommand}" />
                        </StackPanel>
                    </ui:Card>
                    <ui:Card Padding="12">
                        <StackPanel>
                            <TextBlock Text="Профиль эксперта (баланс)" FontWeight="SemiBold" Margin="0,0,0,6" />
                            <TextBlock Text="Создаёт запись ExpertInfo со стартовым балансом. Пользователь уже должен иметь роль Expert."
                                       Opacity="0.5" FontSize="12" TextWrapping="Wrap" Margin="0,0,0,8" />
                            <DockPanel Margin="0,0,0,8">
                                <TextBlock DockPanel.Dock="Left" Text="Стартовый баланс:" VerticalAlignment="Center" Margin="0,0,8,0" />
                                <ui:TextBox Width="100" Text="{Binding ExpertInfoBalance}" />
                            </DockPanel>
                            <ui:Button Content="Создать профиль" Command="{Binding CreateExpertInfoCommand}" />
                        </StackPanel>
                    </ui:Card>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
