<UserControl x:Class="ExpertAdminTrainerApp.Presentation.Views.ToolsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml">

    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <TextBlock Grid.Row="0" Text="Валидация AnswerPayload JSON — вставьте JSON и проверьте контракт."
                   Opacity="0.5" Margin="0,0,0,6" />
        <ui:TextBox Grid.Row="1" AcceptsReturn="True" TextWrapping="Wrap"
                    VerticalScrollBarVisibility="Auto"
                    Text="{Binding PayloadToValidate, UpdateSourceTrigger=PropertyChanged}" />
        <ui:Button Grid.Row="2" Width="220" Margin="0,8,0,0" Appearance="Secondary"
                   Content="Проверить payload" Command="{Binding ValidatePayloadCommand}" />
    </Grid>
</UserControl>
