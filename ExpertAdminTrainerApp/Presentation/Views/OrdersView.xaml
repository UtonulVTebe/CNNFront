<UserControl x:Class="ExpertAdminTrainerApp.Presentation.Views.OrdersView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:controls="clr-namespace:ExpertAdminTrainerApp.Presentation.Controls"
             xmlns:converters="clr-namespace:ExpertAdminTrainerApp.Presentation.Converters">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolVis" />
        <converters:OrderAnswerStatusToRussianConverter x:Key="OrderStatusRu" />
    </UserControl.Resources>

    <Grid Margin="8">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="340" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Левая колонка: очередь и «мои в работе» -->
        <ui:Card Grid.Column="0" Margin="0,0,8,0" Padding="12,10">
            <DockPanel>
                <StackPanel DockPanel.Dock="Top" Margin="0,0,0,10">
                    <ui:TextBlock FontTypography="BodyStrong" Text="Заказы" Margin="0,0,0,4" />
                    <TextBlock TextWrapping="Wrap" Opacity="0.62" FontSize="13"
                               Text="Выберите заказ в списке — справа откроются сведения и действия." />
                    <Expander Margin="0,8,0,0" Header="Справка" FontSize="13" Opacity="0.85">
                        <TextBlock TextWrapping="Wrap" Margin="0,6,0,0" FontSize="12" Opacity="0.75"
                                   Text="Очередь: при фильтре «по умолчанию сервера» список совпадает с ответом API. «Взять в работу» доступно для заказа «В очереди на проверку», для ролей эксперт и администратор, если заказ не с вашего аккаунта. Нужен профиль эксперта на сервере — иначе операция будет отклонена." />
                    </Expander>
                </StackPanel>
                <TabControl BorderThickness="0" Background="Transparent">
                    <TabItem Header="Очередь">
                        <DockPanel Margin="0,8,0,0">
                            <StackPanel DockPanel.Dock="Top" Margin="0,0,0,10">
                                <TextBlock Text="Статус в списке" Opacity="0.65" FontSize="13" Margin="0,0,0,4" />
                                <ComboBox Margin="0,0,0,8"
                                          ItemsSource="{Binding QueueStatusOptions}"
                                          SelectedItem="{Binding QueueStatusFilter}" />
                                <ui:Button HorizontalAlignment="Stretch"
                                           Appearance="Primary"
                                           Content="Обновить очередь"
                                           Command="{Binding LoadQueueCommand}" />
                            </StackPanel>
                            <ListBox Margin="0,4,0,0"
                                     ItemsSource="{Binding QueueOrders}"
                                     SelectedItem="{Binding SelectedQueueOrder}"
                                     BorderThickness="0"
                                     Background="Transparent">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Margin="2,6">
                                            <TextBlock FontWeight="SemiBold">
                                                <Run Text="Заказ №" /><Run Text="{Binding Id, Mode=OneWay}" />
                                            </TextBlock>
                                            <TextBlock Opacity="0.7" FontSize="14">
                                                <Run Text="Вариант КИМ: " /><Run Text="{Binding CnnId, Mode=OneWay}" />
                                                <Run Text="  Ученик: " /><Run Text="{Binding UserId, Mode=OneWay}" />
                                            </TextBlock>
                                            <TextBlock FontSize="14"
                                                       Foreground="{DynamicResource AccentFillColorDefaultBrush}"
                                                       Text="{Binding Status, Converter={StaticResource OrderStatusRu}}" />
                                        </StackPanel>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </DockPanel>
                    </TabItem>
                    <TabItem Header="Мои в работе">
                        <DockPanel Margin="0,8,0,0">
                            <StackPanel DockPanel.Dock="Top" Margin="0,0,0,10">
                                <TextBlock Text="Период изменения (необязательно)" Opacity="0.65" FontSize="13" Margin="0,0,0,4" />
                                <TextBlock TextWrapping="Wrap" Opacity="0.5" FontSize="12" Margin="0,0,0,6"
                                           Text="Ограничить список по дате последнего изменения заказа." />
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <DatePicker Grid.Column="0" Margin="0,0,4,0"
                                                SelectedDate="{Binding ExpertMyOrdersFrom}" />
                                    <DatePicker Grid.Column="1" Margin="4,0,0,0"
                                                SelectedDate="{Binding ExpertMyOrdersTo}" />
                                </Grid>
                                <ui:Button HorizontalAlignment="Stretch"
                                           Appearance="Primary"
                                           Content="Загрузить мои заказы"
                                           Command="{Binding LoadMyCheckingCommand}" />
                            </StackPanel>
                            <ListBox Margin="0,4,0,0"
                                     ItemsSource="{Binding MyCheckingOrders}"
                                     SelectedItem="{Binding SelectedQueueOrder}"
                                     BorderThickness="0"
                                     Background="Transparent">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Margin="2,6">
                                            <TextBlock FontWeight="SemiBold">
                                                <Run Text="Заказ №" /><Run Text="{Binding Id, Mode=OneWay}" />
                                            </TextBlock>
                                            <TextBlock Opacity="0.7" FontSize="14">
                                                <Run Text="Вариант КИМ: " /><Run Text="{Binding CnnId, Mode=OneWay}" />
                                            </TextBlock>
                                            <TextBlock FontSize="14"
                                                       Foreground="{DynamicResource AccentFillColorDefaultBrush}"
                                                       Text="{Binding Status, Converter={StaticResource OrderStatusRu}}" />
                                        </StackPanel>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </DockPanel>
                    </TabItem>
                </TabControl>
            </DockPanel>
        </ui:Card>

        <!-- Right: Order Detail -->
        <Border Grid.Column="1" Padding="4">
            <Grid>
                <TextBlock Text="Выберите заказ в «Очереди» или «Мои в работе»"
                           VerticalAlignment="Center" HorizontalAlignment="Center"
                           Opacity="0.4" FontSize="16"
                           Visibility="{Binding HasNoSelectedOrder, Converter={StaticResource BoolVis}}" />

                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              Visibility="{Binding HasSelectedOrder, Converter={StaticResource BoolVis}}">
                    <StackPanel>
                        <ui:TextBlock FontTypography="Subtitle" FontSize="19">
                            <Run Text="Заказ #" /><Run Text="{Binding SelectedQueueOrder.Id, Mode=OneWay}" />
                        </ui:TextBlock>

                        <Grid Margin="0,8,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition /><RowDefinition /><RowDefinition /><RowDefinition /><RowDefinition />
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Статус:" FontWeight="SemiBold" Margin="0,0,12,4"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding SelectedOrderStatusText}" />
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Студент:" FontWeight="SemiBold" Margin="0,0,12,4"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding SelectedQueueOrder.UserId, StringFormat=User #{0}}" />
                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Эксперт:" FontWeight="SemiBold" Margin="0,0,12,4"/>
                            <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding SelectedQueueOrder.ExpertId, TargetNullValue='(не назначен)'}" />
                            <TextBlock Grid.Row="3" Grid.Column="0" Text="Причина отказа:" FontWeight="SemiBold" Margin="0,0,12,4"
                                       Visibility="{Binding SelectedQueueOrder.RejectionReason, Converter={StaticResource BoolVis}}" />
                            <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding SelectedQueueOrder.RejectionReason}"
                                       Foreground="OrangeRed" TextWrapping="Wrap"
                                       Visibility="{Binding SelectedQueueOrder.RejectionReason, Converter={StaticResource BoolVis}}" />
                            <TextBlock Grid.Row="4" Grid.Column="0" Text="Изменен:" FontWeight="SemiBold" Margin="0,0,12,4"/>
                            <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding SelectedQueueOrder.ChangedAt}" />
                        </Grid>

                        <ui:Card Padding="10" Margin="0,10,0,0">
                            <StackPanel>
                                <TextBlock Text="Ответ ученика" FontWeight="SemiBold" />
                                <DockPanel Margin="0,4,0,0">
                                    <ui:Button DockPanel.Dock="Right" Appearance="Transparent" Content="Открыть"
                                               Command="{Binding OpenUrlCommand}"
                                               CommandParameter="{Binding SelectedQueueOrder.AnswerUrl}" />
                                    <TextBlock Text="{Binding SelectedQueueOrder.AnswerUrl, TargetNullValue='(нет ссылки)'}"
                                               TextTrimming="CharacterEllipsis" VerticalAlignment="Center" Opacity="0.7" />
                                </DockPanel>
                            </StackPanel>
                        </ui:Card>

                        <TextBlock Margin="0,8,0,0" Text="{Binding OrderSubmissionLoadError}" TextWrapping="Wrap"
                                   Foreground="#C42B1C" FontSize="13"
                                   Visibility="{Binding HasOrderSubmissionLoadError, Converter={StaticResource BoolVis}}" />

                        <Expander Margin="0,8,0,0" Background="Transparent" FontSize="13">
                            <Expander.Header>
                                <TextBlock Text="Если превью или сводка не появились — что проверить" TextWrapping="Wrap"
                                           Opacity="0.88" />
                            </Expander.Header>
                            <TextBlock Margin="0,8,0,0" TextWrapping="Wrap" FontSize="12" Opacity="0.78" LineHeight="18"
                                       Text="• По ссылке «Ответ ученика» (answerUrl) должен отдаваться JSON пакета: template.pages, answers (ключи «индексСтраницы|idЗоны»), опционально answerPayload.Exp_Part — сводка развёрнутой части.&#10;• Сканы бланка №2: у CNN нужен материал «Бланки» с заголовком «Разметка бланков (JSON)» — от его URL строятся пути к изображениям.&#10;• Регистрация и бланк №1 в превью не показываются — только развёрнутая часть (№2)." />
                        </Expander>

                        <ui:Card Padding="10" Margin="0,6,0,0"
                                 Visibility="{Binding HasOrderExpPartRows, Converter={StaticResource BoolVis}}">
                            <StackPanel>
                                <TextBlock Text="Развёрнутая часть (сводка из пакета)" FontWeight="SemiBold" Margin="0,0,0,4" />
                                <TextBlock TextWrapping="Wrap" Opacity="0.55" FontSize="13" Margin="0,0,0,8"
                                           Text="Поля answerPayload.Exp_Part: задание, тип ответа, текст (или пометка о PDF)." />
                                <DataGrid ItemsSource="{Binding OrderExpPartRows}" AutoGenerateColumns="False"
                                          IsReadOnly="True" HeadersVisibility="Column" MaxHeight="220"
                                          CanUserAddRows="False" GridLinesVisibility="Horizontal">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Задание" Binding="{Binding TaskId}" Width="70" />
                                        <DataGridTextColumn Header="Тип" Binding="{Binding Type}" Width="60" />
                                        <DataGridTextColumn Header="Ответ" Binding="{Binding Answer}" Width="*" />
                                    </DataGrid.Columns>
                                </DataGrid>
                            </StackPanel>
                        </ui:Card>

                        <TextBlock Margin="0,8,0,0" TextWrapping="Wrap" FontSize="13" Opacity="0.75"
                                   Visibility="{Binding ShowOrderSubmissionNoSheet2Hint, Converter={StaticResource BoolVis}}"
                                   Text="В шаблоне этого варианта нет страниц бланка ответов №2 (AnswerSheet2). Проверяйте развёрнутую часть по сводке выше и по материалам КИМ." />

                        <ui:Card Padding="10" Margin="0,6,0,0"
                                 Visibility="{Binding HasOrderExpertSheet2Pages, Converter={StaticResource BoolVis}}">
                            <StackPanel>
                                <TextBlock Text="Бланк ответов №2 (скан и ответы в зонах)" FontWeight="SemiBold" Margin="0,0,0,4" />
                                <TextBlock TextWrapping="Wrap" Opacity="0.55" FontSize="13" Margin="0,0,0,8"
                                           Text="Только листы бланка №2; порядок и Id зон совпадают с пакетом ученика. Скан подгружается по шаблону и материалу «Разметка бланков (JSON)»." />
                                <DockPanel Margin="0,0,0,8">
                                    <TextBlock DockPanel.Dock="Left" Text="Страница:" VerticalAlignment="Center"
                                               Margin="0,0,8,0" />
                                    <ComboBox ItemsSource="{Binding OrderExpertSheet2Pages}"
                                              SelectedItem="{Binding SelectedOrderExpertSheet2Page, Mode=TwoWay}"
                                              DisplayMemberPath="DisplayLabel" />
                                </DockPanel>
                                <DockPanel Margin="0,0,0,8">
                                    <TextBlock DockPanel.Dock="Left" Text="Масштаб:" VerticalAlignment="Center"
                                               Margin="0,0,8,0" />
                                    <Slider Minimum="0.5" Maximum="2" TickFrequency="0.25" IsSnapToTickEnabled="True"
                                            Value="{Binding OrderPreviewZoom}" AutoToolTipPlacement="TopLeft" />
                                </DockPanel>
                                <Border BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}" BorderThickness="1"
                                        CornerRadius="4" ClipToBounds="True" MinHeight="200" MaxHeight="720"
                                        UseLayoutRounding="True" SnapsToDevicePixels="True">
                                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                                  HorizontalScrollBarVisibility="Auto"
                                                  UseLayoutRounding="True">
                                        <Grid HorizontalAlignment="Left" VerticalAlignment="Top"
                                              UseLayoutRounding="True" SnapsToDevicePixels="True">
                                            <Grid.LayoutTransform>
                                                <ScaleTransform ScaleX="{Binding OrderPreviewZoom}"
                                                                ScaleY="{Binding OrderPreviewZoom}" />
                                            </Grid.LayoutTransform>
                                            <controls:BlankSubmissionReviewCanvas MinWidth="920" MinHeight="640"
                                                                                  Zones="{Binding OrderSubmissionCurrentZones}"
                                                                                  ImageSource="{Binding OrderSubmissionPageImage}"
                                                                                  PageIndex="{Binding OrderSubmissionTemplatePageIndex}"
                                                                                  AnswerSink="{Binding OrderSubmissionAnswerSink}" />
                                        </Grid>
                                    </ScrollViewer>
                                </Border>
                            </StackPanel>
                        </ui:Card>

                        <Expander Margin="0,6,0,0" IsExpanded="False" Padding="0,4,0,0">
                            <Expander.Header>
                                <TextBlock FontWeight="SemiBold" Text="Задания (КИМ)" />
                            </Expander.Header>
                            <ScrollViewer MaxHeight="160" VerticalScrollBarVisibility="Auto">
                                <StackPanel>
                                    <ItemsControl ItemsSource="{Binding OrderKimMaterials}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <DockPanel Margin="0,2">
                                                    <ui:Button DockPanel.Dock="Right" Appearance="Transparent" Content="Открыть"
                                                               Command="{Binding DataContext.OpenUrlCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                               CommandParameter="{Binding Url}" />
                                                    <TextBlock Text="{Binding Title, TargetNullValue='(без названия)'}"
                                                               VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                                                </DockPanel>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                    <TextBlock Text="(нет)" Opacity="0.35" FontSize="14" Margin="0,4,0,0">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding OrderKimMaterials.Count}" Value="0">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </StackPanel>
                            </ScrollViewer>
                        </Expander>

                        <ui:Card Padding="10" Margin="0,6,0,0"
                                 Visibility="{Binding IsAdminOrExpert, Converter={StaticResource BoolVis}}">
                            <StackPanel>
                                <TextBlock Text="Критерии проверки" FontWeight="SemiBold" Margin="0,0,0,4" />
                                <ItemsControl ItemsSource="{Binding OrderCriteriaMaterials}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <DockPanel Margin="0,2">
                                                <ui:Button DockPanel.Dock="Right" Appearance="Transparent" Content="Открыть"
                                                           Command="{Binding DataContext.OpenUrlCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                           CommandParameter="{Binding Url}" />
                                                <TextBlock Text="{Binding Title, TargetNullValue='(без названия)'}" VerticalAlignment="Center" />
                                            </DockPanel>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <TextBlock Text="(нет)" Opacity="0.35" FontSize="14">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding OrderCriteriaMaterials.Count}" Value="0">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>
                        </ui:Card>

                        <ui:Card Padding="10" Margin="0,10,0,0"
                                 Visibility="{Binding IsAdminOrExpert, Converter={StaticResource BoolVis}}">
                            <StackPanel>
                                <TextBlock Text="Действия по заказу" FontWeight="SemiBold" Margin="0,0,0,8" />
                                <WrapPanel Margin="0,0,0,8">
                                    <ui:Button Appearance="Primary" Margin="0,0,8,0" Content="Взять в работу"
                                               Command="{Binding ClaimSelectedOrderCommand}"
                                               IsEnabled="{Binding CanClaimSelectedOrder}" />
                                    <ui:Button Appearance="Danger" Content="Отклонить"
                                               Command="{Binding BeginRejectOrderCommand}"
                                               IsEnabled="{Binding CanRejectSelectedOrder}" />
                                </WrapPanel>
                                <StackPanel Visibility="{Binding IsRejectingOrder, Converter={StaticResource BoolVis}}">
                                    <ui:TextBox PlaceholderText="Причина отклонения (обязательно, до 1024 символов)"
                                                Text="{Binding RejectionReason, UpdateSourceTrigger=PropertyChanged}"
                                                MaxLength="1024"
                                                Margin="0,0,0,6" AcceptsReturn="True" Height="60" />
                                    <WrapPanel>
                                        <ui:Button Appearance="Danger" Content="Подтвердить отклонение" Margin="0,0,8,0"
                                                   Command="{Binding ConfirmRejectOrderCommand}" />
                                        <ui:Button Appearance="Secondary" Content="Отмена"
                                                   Command="{Binding CancelRejectOrderCommand}" />
                                    </WrapPanel>
                                </StackPanel>
                            </StackPanel>
                        </ui:Card>

                        <ui:Card Padding="10" Margin="0,8,0,0"
                                 Visibility="{Binding IsAdminOrExpert, Converter={StaticResource BoolVis}}">
                            <StackPanel>
                                <DockPanel Margin="0,0,0,6">
                                    <ui:Button DockPanel.Dock="Right" Appearance="Transparent"
                                               Content="Редактировать проверку"
                                               Command="{Binding BeginEditReviewCommand}"
                                               IsEnabled="{Binding CanOpenReviewEditor}" />
                                    <TextBlock Text="Проверка (Review)" FontWeight="SemiBold" VerticalAlignment="Center" />
                                </DockPanel>
                                <StackPanel Visibility="{Binding HasReview, Converter={StaticResource BoolVis}}">
                                    <TextBlock>
                                        <Run Text="Итоговый балл: " FontWeight="SemiBold" />
                                        <Run Text="{Binding CurrentReview.TotalScore, Mode=OneWay}" />
                                    </TextBlock>
                                    <TextBlock Text="{Binding CurrentReview.GeneralComment}" Opacity="0.7" Margin="0,2,0,4" TextWrapping="Wrap" />
                                    <ItemsControl ItemsSource="{Binding ReviewCriteria}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock FontSize="14" Opacity="0.7" Margin="0,1" TextWrapping="Wrap">
                                                    <Run Text="Зад. " /><Run Text="{Binding TaskNumber, Mode=OneWay}" />
                                                    <Run Text=" | " /><Run Text="{Binding CriterionCode, Mode=OneWay}" />
                                                    <Run Text=" = " /><Run Text="{Binding Score, Mode=OneWay}" />
                                                    <Run Text=" балл(ов)" />
                                                    <Run Text=" — " /><Run Text="{Binding Comment, Mode=OneWay}" />
                                                </TextBlock>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                                <TextBlock Text="Проверка ещё не заполнена" Opacity="0.4"
                                           Visibility="{Binding HasNoReview, Converter={StaticResource BoolVis}}" />
                                <Border Margin="0,8,0,0" Padding="10" CornerRadius="6"
                                        Background="{DynamicResource ControlFillColorDefaultBrush}"
                                        Visibility="{Binding IsEditingReview, Converter={StaticResource BoolVis}}">
                                    <StackPanel>
                                        <Grid Margin="0,0,0,6">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="Итог (баллы):" VerticalAlignment="Center" Margin="0,0,8,0" />
                                            <ui:TextBox Grid.Column="1" Text="{Binding ReviewTotalScore}" />
                                        </Grid>
                                        <ui:TextBox PlaceholderText="Общий комментарий (до 2048 символов)"
                                                    Text="{Binding ReviewGeneralComment, UpdateSourceTrigger=PropertyChanged}"
                                                    MaxLength="2048"
                                                    Margin="0,0,0,6" AcceptsReturn="True" Height="50" />
                                        <TextBlock Text="Критерии:" FontWeight="SemiBold" Margin="0,0,0,4" />
                                        <ItemsControl ItemsSource="{Binding ReviewCriteria}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Grid Margin="0,2">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="60" />
                                                            <ColumnDefinition Width="90" />
                                                            <ColumnDefinition Width="60" />
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>
                                                        <ui:TextBox Grid.Column="0" Margin="0,0,4,0" PlaceholderText="Зад."
                                                                    Text="{Binding TaskNumber, UpdateSourceTrigger=PropertyChanged}" />
                                                        <ui:TextBox Grid.Column="1" Margin="0,0,4,0" PlaceholderText="Код"
                                                                    MaxLength="32"
                                                                    Text="{Binding CriterionCode, UpdateSourceTrigger=PropertyChanged}" />
                                                        <ui:TextBox Grid.Column="2" Margin="0,0,4,0" PlaceholderText="Балл"
                                                                    Text="{Binding Score, UpdateSourceTrigger=PropertyChanged}" />
                                                        <ui:TextBox Grid.Column="3" Margin="0,0,4,0" PlaceholderText="Комментарий"
                                                                    MaxLength="1024"
                                                                    Text="{Binding Comment, UpdateSourceTrigger=PropertyChanged}" />
                                                        <ui:Button Grid.Column="4" Appearance="Danger" Content="✕"
                                                                   Command="{Binding DataContext.RemoveReviewCriterionCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                   CommandParameter="{Binding}" />
                                                    </Grid>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                        <WrapPanel Margin="0,8,0,0">
                                            <ui:Button Appearance="Transparent" Content="+ Критерий" Margin="0,0,6,0"
                                                       Command="{Binding AddReviewCriterionCommand}" />
                                            <ui:Button Appearance="Primary" Content="Сохранить проверку" Margin="0,0,6,0"
                                                       Command="{Binding SaveReviewCommand}" />
                                            <ui:Button Appearance="Secondary" Content="Отмена"
                                                       Command="{Binding CancelEditReviewCommand}" />
                                        </WrapPanel>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </ui:Card>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</UserControl>
