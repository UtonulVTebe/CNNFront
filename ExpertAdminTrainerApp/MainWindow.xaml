<ui:FluentWindow x:Class="ExpertAdminTrainerApp.MainWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                 xmlns:local="clr-namespace:ExpertAdminTrainerApp"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 mc:Ignorable="d"
                 Title="Демо WPF UI"
                 Width="560"
                 Height="680"
                 MinWidth="420"
                 WindowStartupLocation="CenterScreen"
                 ExtendsContentIntoTitleBar="True"
                 WindowBackdropType="Mica">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="Expert Admin — пробное окно" />

        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      Padding="16,12,16,20">
            <StackPanel Orientation="Vertical">

                <ui:TextBlock Margin="0,0,0,16"
                              FontTypography="BodyStrong"
                              Text="Несколько контролов из WPF UI (lepoco): окно с Mica, карточки, кнопки, поле ввода, переключатель и индикатор загрузки."
                              TextWrapping="Wrap"
                              Foreground="{DynamicResource TextFillColorSecondaryBrush}" />

                <ui:Card Margin="0,0,0,16" Padding="16">
                    <StackPanel>
                        <ui:TextBlock Margin="0,0,0,10" FontTypography="Subtitle" Text="Кнопки" />
                        <WrapPanel Orientation="Horizontal">
                            <ui:Button Margin="0,0,8,8"
                                       Appearance="Primary"
                                       Click="OnDemoDialogClick"
                                       Content="Диалог"
                                       Icon="{ui:SymbolIcon Symbol=Chat24}" />
                            <ui:Button Margin="0,0,8,8"
                                       Appearance="Secondary"
                                       Content="Вторичная"
                                       Icon="{ui:SymbolIcon Symbol=Settings24}" />
                            <ui:Button Margin="0,0,8,8"
                                       Appearance="Light"
                                       Content="Светлая"
                                       Icon="{ui:SymbolIcon Symbol=Star24}" />
                            <ui:Button Margin="0,0,8,8"
                                       Appearance="Transparent"
                                       Content="Прозрачная"
                                       Icon="{ui:SymbolIcon Symbol=Info24}" />
                        </WrapPanel>
                    </StackPanel>
                </ui:Card>

                <ui:Card Margin="0,0,0,16" Padding="16">
                    <StackPanel>
                        <ui:TextBlock Margin="0,0,0,8" FontTypography="Subtitle" Text="Поле ввода" />
                        <ui:TextBox x:Name="DemoSearchBox"
                                    PlaceholderText="Поиск или заметка…"
                                    ClearButtonEnabled="True" />
                    </StackPanel>
                </ui:Card>

                <ui:Card Margin="0,0,0,16" Padding="16">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <ui:TextBlock FontTypography="Subtitle" Text="Переключатель" />
                            <ui:TextBlock Margin="0,4,0,0"
                                          FontTypography="Caption"
                                          Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                          Text="Стиль как в настройках Windows 11" />
                        </StackPanel>
                        <ui:ToggleSwitch Grid.Column="1"
                                         VerticalAlignment="Center"
                                         Content="Включено"
                                         IsChecked="True" />
                    </Grid>
                </ui:Card>

                <ui:Card Padding="16">
                    <StackPanel HorizontalAlignment="Left" Orientation="Horizontal">
                        <StackPanel Margin="0,0,24,0" VerticalAlignment="Center">
                            <ui:TextBlock FontTypography="Subtitle" Text="Загрузка" />
                            <ui:TextBlock Margin="0,4,0,0"
                                          FontTypography="Caption"
                                          Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                          Text="ProgressRing" />
                        </StackPanel>
                        <ui:ProgressRing Width="40"
                                         Height="40"
                                         IsIndeterminate="True" />
                    </StackPanel>
                </ui:Card>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</ui:FluentWindow>
