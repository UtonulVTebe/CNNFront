<ui:FluentWindow x:Class="ExpertAdminTrainerApp.MainWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 xmlns:views="clr-namespace:ExpertAdminTrainerApp.Presentation.Views"
                 mc:Ignorable="d"
                 Title="ExpertAdminTrainerApp"
                 Width="1200"
                 Height="820"
                 MinWidth="980"
                 MinHeight="620"
                 Loaded="OnLoaded"
                 WindowStartupLocation="CenterScreen"
                 ExtendsContentIntoTitleBar="True"
                 WindowBackdropType="Mica">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolVis" />
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="Expert / Admin — EGE Trainer Platform" />

        <!-- Auth Bar -->
        <ui:Card Grid.Row="1" Padding="14" Margin="16,0,16,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <WrapPanel VerticalAlignment="Center">
                    <ui:TextBox Width="240" Margin="0,0,6,0" PlaceholderText="Email"
                                Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}" />
                    <ui:PasswordBox x:Name="PwdBox" Width="180" Margin="0,0,6,0" PlaceholderText="Пароль"
                                    Password="{Binding Password, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    <ui:Button Appearance="Primary" Margin="0,0,6,0" Content="Войти" Click="OnLoginClick" />
                    <ui:Button Appearance="Secondary" Content="Выйти" Command="{Binding LogoutCommand}" />
                </WrapPanel>
                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="12,0"
                            Visibility="{Binding IsAuthenticated, Converter={StaticResource BoolVis}}">
                    <TextBlock Text="{Binding UserName}" FontWeight="SemiBold" />
                    <TextBlock Text="{Binding Role, StringFormat=Роль: {0}}" Opacity="0.6" FontSize="12" />
                </StackPanel>
                <ui:ProgressRing Grid.Column="2" Width="24" Height="24" IsIndeterminate="{Binding IsBusy}" />
            </Grid>
        </ui:Card>

        <TextBlock Grid.Row="2" Text="{Binding StatusText}" Margin="20,6,20,4" Opacity="0.6" FontSize="12" />

        <!-- Main Workspace -->
        <TabControl Grid.Row="3" Margin="16,0,16,16"
                    Visibility="{Binding IsAdminOrExpert, Converter={StaticResource BoolVis}}">

            <TabItem Header="Заказы">
                <views:OrdersView />
            </TabItem>

            <TabItem Header="Каталог и материалы"
                     Visibility="{Binding IsAdmin, Converter={StaticResource BoolVis}}">
                <views:CatalogView />
            </TabItem>

            <TabItem Header="Пользователи"
                     Visibility="{Binding IsAdmin, Converter={StaticResource BoolVis}}">
                <views:UsersView />
            </TabItem>

            <TabItem Header="Конструктор бланков"
                     Visibility="{Binding IsAdmin, Converter={StaticResource BoolVis}}">
                <views:ConstructorView DataContext="{Binding ConstructorVm, RelativeSource={RelativeSource AncestorType=Window}}" />
            </TabItem>

            <TabItem Header="Инструменты">
                <views:ToolsView />
            </TabItem>
        </TabControl>
    </Grid>
</ui:FluentWindow>
